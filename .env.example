# Copy to ".env" and fill in. All VITE_* vars are exposed to the browser
# (safe for Firebase web config + public URLs, NOT for secret API keys).

# --- Google Analytics 4 (optional) ---
# From your own GA4 property. Leave unset to disable analytics.
VITE_GA_ID=

# --- AI Chatbot ---
# URL of your deployed `chat` Cloud Function. Leave unset to disable the bot.
# e.g. https://us-central1-<your-project>.cloudfunctions.net/chat
VITE_CHAT_API_URL=

# --- Firebase (your own project — see #5) ---
# Leave unset to keep the current fallback config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=

# NOTE: The OpenAI API key is NOT here — it lives server-side as a Firebase
# secret. Set it with:  firebase functions:secrets:set OPENAI_API_KEY

# --- Scheduling (optional) ---
# Your Calendly (or similar) link for the "Book a Call" button.
VITE_CALENDLY_URL=

# --- Resume Analyzer (optional) ---
# Deployed analyzeResume Cloud Function URL.
VITE_ANALYZE_API_URL=
