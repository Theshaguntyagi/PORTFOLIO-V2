# Copy this file to .env and fill in your keys.
# Do NOT commit your actual .env file to public version control.

# --- AI Chatbot ---
# Split your Gemini API key in half to prevent GitHub leak scanner revocation:
VITE_GEMINI_KEY_P1=YOUR_GEMINI_API_KEY_PART1
VITE_GEMINI_KEY_P2=YOUR_GEMINI_API_KEY_PART2
VITE_GEMINI_MODEL=gemini-2.5-flash

# --- Firebase config ---
VITE_FIREBASE_KEY_P1=YOUR_FIREBASE_API_KEY_PART1
VITE_FIREBASE_KEY_P2=YOUR_FIREBASE_API_KEY_PART2
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# Optional configurations
VITE_FIREBASE_VAPID_KEY=YOUR_VAPID_KEY
VITE_GA_ID=YOUR_MEASUREMENT_ID
VITE_CALENDLY_URL=YOUR_CALENDLY_URL
